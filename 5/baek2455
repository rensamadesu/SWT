a1, b1 = map(int, input().split())
a2, b2 = map(int, input().split())
a3, b3 = map(int, input().split())
a4, b4 = map(int, input().split())

station1 = b1-a1 # 각 역마다 사람의 수를 
station2 = station1+(b2-a2)
station3 = station2+(b3-a3)
station4 = station3+(b4-a4)
max_station = max([station1, station2, station3, station4]) # 대괄호에 넣어서 리스트로 만들기
print(max_station)
