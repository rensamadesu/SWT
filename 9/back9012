a = int(input())

for i in range(a) :
    
    b = list(input())
    result = []
    
    nice = True

    for j in b :
        
        if j == '(' :
            result.append(j)
        
        elif  j == ')' :
            if len(result) > 0 :
                    result.pop()
            else :
                nice = False 
                break
    if len(result) == 0 and nice == True :
        print("YES")
    else :
        print("NO")
