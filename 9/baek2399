a = int(input())
b = list(map(int, input().split()))
b.sort()
total = 0 

for i in range(a) :
   plus_count = i
   minus_count = a - 1 - i
   total += (b[i] * plus_count)
   total -= (b[i] * minus_count)

print(total * 2) 


