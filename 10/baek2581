a = int(input())
b = int(input())
num = []

for i in range(a, b + 1, 1) :
    if i == 1 :
        continue
    
    is_prime = True
    
    for j in range(2, i) :
        if i % j == 0 :
            is_prime = False
            break
        
    if  is_prime :
        num.append(i)
            
if len(num) > 0 :
    print(sum(num))
    print(min(num))
else :
    print(-1)
